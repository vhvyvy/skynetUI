# Скопируй в .env и заполни значения
# Для Streamlit используй .streamlit/secrets.toml

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DB=skynet
PG_USER=postgres
PG_PASSWORD=

# Notion (для sync)
NOTION_TOKEN=

# OpenAI (опционально, для AI-вкладки)
# OPENAI_API_KEY=sk-...

# Onlymonster API (вкладки KPI, Сабы)
# ONLYMONSTER_API_URL=https://omapi.onlymonster.ai
# ONLYMONSTER_API_KEY=твой_токен
# Только эти ID аккаунтов подтягиваются в Сабы (через запятую). Пусто = все аккаунты.
# ONLYMONSTER_ACCOUNT_IDS=23676,34920,37356
